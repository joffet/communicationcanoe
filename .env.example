# Supabase (Postgres + Realtime only — auth is Better Auth in Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-secret-key

# Better Auth (uses Supabase Postgres via DATABASE_URL)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Postmark (inbound)
POSTMARK_INBOUND_WEBHOOK_SECRET=

# AI (one provider required for live AI)
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Internal (future bridge ↔ web)
INTERNAL_API_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated emails auto-promoted to super_admin on login (optional bootstrap)
SUPER_ADMIN_EMAILS=

# Public URL for email image assets when running locally (optional)
# EMAIL_ASSET_BASE_URL=https://your-production-domain.com

# Amazon SES (outbound email — magic links, tenant replies)
AMAZON_SES_REGION=ca-central-1
AWS_REGION=ca-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Default From when no tenant address is available (verified in SES)
DEFAULT_MAIL_FROM=info@communicationcanoe.com

# Voice bridge (set in Railway for voice-bridge service only — not apps/web)
# VOICE_BRIDGE_PORT=3001
